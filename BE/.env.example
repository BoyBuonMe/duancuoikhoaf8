PORT=3001
NODE_ENV=development
MONGODB_URL=mongodb://127.0.0.1:27017
MONGODB_DATABASE=e-commerce
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
APP_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-with-smtp-username
SMTP_PASS=replace-with-smtp-app-password
MAIL_FROM=replace-with-sender-email
STORE_NAME=Gymshark
STORE_SUPPORT_EMAIL=dphattt@gmail.com
STORE_HOTLINE=1900 1234
STORE_LOGO_URL=https://your-cdn.com/gymshark-logo.png
# MoMo sandbox — payWithMethod opens web checkout (ATM/card/wallet). captureWallet = MoMo QR only.
MOMO_REQUEST_TYPE=payWithMethod
# Public HTTPS URL MoMo can reach for IPN + redirect (ngrok, localtunnel). Required for ATM/Napas flow.
# Run: npm run tunnel:momo — copy the printed URL here, restart BE.
MOMO_PUBLIC_API_ORIGIN=
# Optional overrides (ignored when MOMO_PUBLIC_API_ORIGIN is set):
# MOMO_REDIRECT_URL=
# MOMO_IPN_URL=
# API_ORIGIN=http://localhost:3001

# Soketi (Pusher-compatible WebSocket) — support chat realtime
# Local: terminal 1 → npm run soketi | terminal 2 → npm run dev
PUSHER_APP_ID=app-id
PUSHER_APP_KEY=app-key
PUSHER_APP_SECRET=app-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
# Docker compose: PUSHER_HOST=soketi

# AI chat (AeroLink — OpenAI-compatible gateway, used by src/models/chat/ai.service.ts)
# Without AI_KEY the assistant returns a "system busy" fallback message.
AI_KEY=
OPENAI_MODEL=anthropic/claude-opus-4.8
